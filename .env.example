# Copy this to .env (gitignored) and fill in real values.
# Do NOT commit .env. All keys are read by the Electron main process only.

# GBrain MCP — set this AFTER you run `gbrain auth register-client closer ...`
GBRAIN_HTTP_URL=http://localhost:3131
GBRAIN_CLIENT_ID=
GBRAIN_CLIENT_SECRET=

# HOG (developer.thehog.ai)
HOG_ACCESS_KEY=ak_REPLACE_ME
HOG_SECRET_KEY=sk_REPLACE_ME

# Groq (Whisper batch + chat completions)
GROQ_API_KEY=

# Anthropic (subagent drafting + Live Coach)
ANTHROPIC_API_KEY=

# ZeroEntropy (Relevance Agent rerank)
ZEROENTROPY_API_KEY=

# Demo wedge (tunes prompts; defaults to Arvya's PE/IB wedge)
DEMO_WEDGE="Outlook-native PE/IB deal teams with DealCloud + stale CRM + buyer-tracker pain"
